---
import { getCollection, render, type CollectionEntry } from "astro:content";
import SiteLayout from "../../layouts/SiteLayout.astro";

export async function getStaticPaths() {
  const projects = await getCollection("projects", ({ data }) => !data.draft);
  return projects.map((project) => ({
    params: { slug: project.id },
    props: { project },
  }));
}

interface Props {
  project: CollectionEntry<"projects">;
}

const { project } = Astro.props;
const { Content } = await render(project);
const base = import.meta.env.BASE_URL.endsWith("/")
  ? import.meta.env.BASE_URL
  : `${import.meta.env.BASE_URL}/`;
---

<SiteLayout
  title={`${project.data.title} — Alfred`}
  description={project.data.description}
  bodyClass="content-page"
>
  <main class="page-main project-page">
    <a class="back-link" href={`${base}projects/`}>← All projects</a>

    <article>
      <header class="project-heading">
        <h1>{project.data.title}</h1>
        <p>{project.data.description}</p>
        <div class="project-meta">
          <span>{project.data.role}</span>
          <time datetime={project.data.date.toISOString()}>{project.data.date.getFullYear()}</time>
        </div>
        {
          project.data.links.length > 0 && (
            <div class="project-links">
              {project.data.links.map((link) => (
                <a href={link.url}>{link.label} ↗</a>
              ))}
            </div>
          )
        }
      </header>

      <div class="prose">
        <Content />
      </div>
    </article>
  </main>
</SiteLayout>
